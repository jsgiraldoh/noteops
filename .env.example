# ─── Base de datos ───────────────────────────────
DATABASE_URL=postgres://noteops:secret@postgres:5432/noteops?sslmode=disable
DB_USER=noteops
DB_PASSWORD=secret
DB_NAME=noteops

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth — CAMBIAR EN PRODUCCIÓN ────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=change-me-minimum-32-characters-long

# ─── App ─────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_DOMAIN=noteops.local

# ─── Frontend (expuesto al browser) ──────────────
PUBLIC_API_URL=http://noteops.local/api
PUBLIC_WS_URL=ws://noteops.local

# ─── Registry GitHub ─────────────────────────────
# Formato: owner/repo (sin ghcr.io/)
GITHUB_REPOSITORY=johansgiraldo/noteops
# Versión a desplegar con perfil registry
TAG=latest

# ─── MinIO — CAMBIAR EN PRODUCCIÓN ───────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Traefik SSL (solo en producción con dominio real) ───
# ACME_EMAIL=tu@email.com

# ─── Red local ───────────────────────────────────
# Agregar a /etc/hosts: 127.0.0.1  noteops.local
